local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ CONFIG ]]
local config = {
    waits = {
        speed = 0.1 -- Czas między kliknięciami (zmień tutaj)
    },
    clicker1 = false,
    clicker2 = false
}

local Window = Rayfield:CreateWindow({
   Name = "VaenzzHub",
   LoadingTitle = "Loading Games...",
   LoadingSubtitle = "by Vaenzz",
   ConfigurationSaving = { Enabled = false }
})

local Tab = Window:CreateTab("Main Farm", 4483362458)

-- [[ PATHS ]]
local plot = workspace.Plots.Plot_1.Plot_Models.BaseModel
local btn1 = plot.ButtonModel.PacketClick:FindFirstChild("ClickDetector")
local btn2 = plot.ButtonModel.PacketClick2:FindFirstChild("ClickDetector")

-- [[ TOGGLES ]]
Tab:CreateToggle({
   Name = "Auto Click Button 1",
   CurrentValue = false,
   Flag = "Toggle1",
   Callback = function(Value)
      config.clicker1 = Value
   end,
})

Tab:CreateToggle({
   Name = "Auto Click Button 2",
   CurrentValue = false,
   Flag = "Toggle2",
   Callback = function(Value)
      config.clicker2 = Value
   end,
})

-- [[ LOOPS ]]
task.spawn(function()
    while true do
        if config.clicker1 and btn1 then 
            fireclickdetector(btn1) 
        end
        task.wait(config.waits.speed)
    end
end)

task.spawn(function()
    while true do
        if config.clicker2 and btn2 then 
            fireclickdetector(btn2) 
        end
        task.wait(config.waits.speed)
    end
end)

Rayfield:Notify({
   Title = "VaenzzHub",
   Content = "Two Toggles Ready",
   Duration = 3,
   Image = 4483362458,
})
