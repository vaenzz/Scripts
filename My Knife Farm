local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Config for easy adjustments
local Config = {
    WaitTime = 0.1, -- Adjust your wait() here
    Enabled = false
}

-- Find the local player's plot
local function getPlayerPlot()
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        if plot:FindFirstChild("Owner") and plot.Owner.Value == game.Players.LocalPlayer.UserId then
            return plot
        elseif plot:GetAttribute("Owner") == game.Players.LocalPlayer.UserId then
            return plot
        end
    end
    return nil
end

local myPlot = getPlayerPlot()

local Window = Rayfield:CreateWindow({
    Name = "Plot Spammer",
    LoadingTitle = "VAENBOT Interface",
    LoadingSubtitle = "by Gemini",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "VaenbotScripts",
        FileName = "PlotConfig"
    }
})

local MainTab = Window:CreateTab("Main", 4483362458)

MainTab:CreateToggle({
    Name = "Auto Fire Upgrade",
    CurrentValue = false,
    Flag = "AutoFire",
    Callback = function(Value)
        Config.Enabled = Value
        if Value then
            task.spawn(function()
                while Config.Enabled do
                    if myPlot then
                        local target = myPlot.Plot_Models.BaseModel.Slots.Slot1.UpgradePart.ClickDetector
                        fireclickdetector(target)
                    else
                        Rayfield:Notify({
                            Title = "Error",
                            Content = "Could not find your plot!",
                            Duration = 5
                        })
                        Config.Enabled = false
                        break
                    end
                    task.wait(Config.WaitTime)
                end
            end)
        end
    end,
})

MainTab:CreateSlider({
    Name = "Wait Delay",
    Min = 0,
    Max = 1,
    DefaultValue = 0.1,
    Color = Color3.fromRGB(255, 255, 255),
    Increment = 0.01,
    ValueName = "Seconds",
    Flag = "DelaySlider",
    Callback = function(Value)
        Config.WaitTime = Value
    end,
})
