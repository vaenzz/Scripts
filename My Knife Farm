local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ CONFIG ]]
local config = {
    waits = {
        speed = 0.1
    },
    clicker1 = false,
    clicker2 = false
}

local Window = Rayfield:CreateWindow({
   Name = "VaenzzHub",
   LoadingTitle = "Loading Games...",
   LoadingSubtitle = "by Vaenzz",
   ConfigurationSaving = { Enabled = false }
})

local Tab = Window:CreateTab("Main Farm", 4483362458)

-- [[ TOGGLES ]]
Tab:CreateToggle({
   Name = "Auto Click Button 1",
   CurrentValue = false,
   Flag = "Toggle1",
   Callback = function(Value)
      config.clicker1 = Value
   end,
})

Tab:CreateToggle({
   Name = "Auto Click Button 2",
   CurrentValue = false,
   Flag = "Toggle2",
   Callback = function(Value)
      config.clicker2 = Value
   end,
})

-- [[ LOOPS WITH DYNAMIC PATHING ]]
task.spawn(function()
    while true do
        if config.clicker1 then
            -- Szukamy przycisku co każdą pętlę, żeby uniknąć błędu nil
            local success, btn = pcall(function() 
                return workspace.Plots.Plot_1.Plot_Models.BaseModel.ButtonModel.PacketClick.ClickDetector 
            end)
            
            if success and btn then
                fireclickdetector(btn)
            end
        end
        task.wait(config.waits.speed)
    end
end)

task.spawn(function()
    while true do
        if config.clicker2 then
            local success, btn = pcall(function() 
                return workspace.Plots.Plot_1.Plot_Models.BaseModel.ButtonModel.PacketClick2.ClickDetector 
            end)
            
            if success and btn then
                fireclickdetector(btn)
            end
        end
        task.wait(config.waits.speed)
    end
end)

Rayfield:Notify({
   Title = "VaenzzHub",
   Content = "Script Ready - Fixed Pathing",
   Duration = 3,
   Image = 4483362458,
})
